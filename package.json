
{
  "name": "nexova-site",
  "version": "1.0.0",
  "private": true,
  "description": "Nexova public website — landing page and talent registration form.",
  "scripts": {
    "build": "tailwindcss -i ./src/input.css -o ./styles.css --minify",
    "watch": "tailwindcss -i ./src/input.css -o ./styles.css --watch",
    "serve": "http-server . -p 3000 -a 0.0.0.0",
    "dev": "npm run watch & npm run serve"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "tailwindcss": "^3.4.13"
  }
}
  